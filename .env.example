# =====================================================================
# AuditChain — Environment variables
# Copy this file to .env and fill in the values.
# Never commit .env to git.
# =====================================================================

# --- LLM API keys (you only need the ones you'll actually use) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Default models (cost-optimized routing) ---
LLM_FAST_MODEL=gpt-4o-mini
LLM_SMART_MODEL=claude-sonnet-4-5-20250929
LLM_EMBEDDING_MODEL=text-embedding-3-small

# --- SEC EDGAR ---
# SEC requires User-Agent identification on all requests
SEC_USER_AGENT="Your Name your.email@example.com"

# --- Database ---
POSTGRES_USER=auditchain
POSTGRES_PASSWORD=auditchain_dev
POSTGRES_DB=auditchain
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://auditchain:auditchain_dev@localhost:5432/auditchain

# --- Observability ---
# LangSmith (optional, free tier available)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=auditchain
LANGSMITH_TRACING=true

# Langfuse (self-hosted, runs locally via docker-compose)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32
LANGFUSE_SALT=replace-with-openssl-rand-hex-32
LANGFUSE_PORT=3000

# --- Application ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Cost guardrails ---
# Max tokens per audit run before requiring confirmation
MAX_TOKENS_PER_RUN=100000
MAX_COST_PER_RUN_USD=1.00
